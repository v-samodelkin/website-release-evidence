{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website Release Evidence Dossier input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "pattern": "^https://",
      "maxLength": 2048,
      "description": "One credential-free public HTTPS release URL on standard port 443."
    }
  }
}
